# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# FIREBASE_PROJECT_ID: The ID of your Firebase project.
FIREBASE_PROJECT_ID="gen-lang-client-0455506485"

# SANITY_PROJECT_ID: Your Sanity project ID
SANITY_PROJECT_ID=""
# SANITY_DATASET: Your Sanity dataset (e.g., "production")
SANITY_DATASET="production"
# SANITY_API_TOKEN: Your Sanity API token with write permissions
SANITY_API_TOKEN=""
